# 🔒 SECURITY: NEVER commit the actual .env file to git!
# Copy this file to .env and replace placeholders with your real values
# All .env files are already gitignored for your protection

# ========================================
# CLOUDFLARE CONFIGURATION
# ========================================
# Create API Token at: https://dash.cloudflare.com/profile/api-tokens
# Required scopes: Zone:Zone:Read, Zone:DNS:Edit, Account:Cloudflare Workers:Edit
CF_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN_HERE
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID_HERE

# ========================================
# DEPLOYMENT SECRETS (Use Wrangler Secrets)
# ========================================
# RECOMMENDED: Set these via Wrangler instead of .env:
# npx wrangler secret put CF_API_TOKEN
# npx wrangler secret put AIRTABLE_API_TOKEN  
# npx wrangler secret put AIRTABLE_BASE_ID
# npx wrangler secret put NETLIFY_API_KEY

# ========================================
# AIRTABLE CONFIGURATION
# ========================================
# Create Personal Access Token at: https://airtable.com/developers/web/api/introduction
# Required scopes: data.records:read, data.records:write for specific base
AIRTABLE_API_TOKEN=patn9EcWwQcOQtP2A.084bc3ecf3d4493db9e4bc215f31a10de83cb9486a1d277c4fdb8a869b379622
AIRTABLE_BASE_ID=appLattdbxMhK4I0y  # Multidomain Management  

# ========================================
# NETLIFY CONFIGURATION
# ========================================
# Create Personal Access Token at: https://app.netlify.com/user/applications/personal
# Required scopes: Minimal scopes for your deployment needs
NETLIFY_API_KEY=YOUR_NETLIFY_API_KEY_HERE

# ========================================
# IMPORTANT SECURITY NOTES
# ========================================
# 1. NEVER commit real secrets to version control
# 2. Use Wrangler secrets for production (npx wrangler secret put KEY)
# 3. Rotate all tokens regularly (recommended: every 90 days)
# 4. Use least-privilege scopes for all tokens
# 5. Store backup tokens securely (password manager)
# 6. Monitor token usage in provider dashboards

