<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Domain Management Dashboard - Control Center</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="js/domain-manager.js" defer></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    :root {
      --bg-primary: #0f0f0f;
      --bg-secondary: #1a1a1a;
      --bg-card: rgba(255,255,255,0.03);
      --border: rgba(255,255,255,0.08);
      --text-primary: #ffffff;
      --text-secondary: #a0a0a0;
      --accent-blue: #3b82f6;
      --accent-green: #10b981;
      --accent-yellow: #f59e0b;
      --accent-red: #ef4444;
      --glass: rgba(255,255,255,0.05);
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      overflow-x: hidden;
    }
    
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 72px;
      background: var(--glass);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      z-index: 1000;
      padding: 0 24px;
    }
    
    .header-content {
      max-width: 1920px;
      margin: 0 auto;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    
    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 20px;
      font-weight: 600;
    }
    
    .logo-icon {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--accent-blue), var(--accent-green));
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .sidebar {
      position: fixed;
      left: 0;
      top: 72px;
      bottom: 0;
      width: 280px;
      background: var(--bg-secondary);
      border-right: 1px solid var(--border);
      padding: 24px;
      overflow-y: auto;
    }
    
    .nav-section { margin-bottom: 32px; }
    
    .nav-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 12px;
    }
    
    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 8px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: all 0.2s;
      margin-bottom: 4px;
      cursor: pointer;
    }
    
    .nav-item:hover {
      background: var(--glass);
      color: var(--text-primary);
    }
    
    .nav-item.active {
      background: var(--accent-blue);
      color: white;
    }
    
    .main-content {
      margin-left: 280px;
      padding: 96px 24px 24px;
      min-height: 100vh;
    }
    
    .container {
      max-width: 1600px;
      margin: 0 auto;
    }
    
    .view-section {
      display: none;
    }
    
    .view-section.active {
      display: block !important;
    }
    
    .page-header { margin-bottom: 32px; }
    .page-title { font-size: 32px; font-weight: 700; margin-bottom: 8px; }
    .page-subtitle { color: var(--text-secondary); font-size: 16px; }
    
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }
    
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
    }
    
    .stat-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px;
    }
    
    .stat-label { color: var(--text-secondary); font-size: 14px; }
    .stat-value { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
    .stat-change { font-size: 14px; }
    .stat-change.positive { color: var(--accent-green); }
    .stat-change.negative { color: var(--accent-red); }
    
    .data-table {
      width: 100%;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }
    
    .data-table thead { background: var(--glass); }
    .data-table th {
      padding: 16px;
      text-align: left;
      font-size: 14px;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .data-table td {
      padding: 16px;
      border-top: 1px solid var(--border);
      font-size: 14px;
    }
    
    .btn {
      padding: 8px 16px;
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 14px;
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .btn:hover {
      background: var(--accent-blue);
      border-color: var(--accent-blue);
    }
    
    .loading-spinner {
      width: 40px;
      height: 40px;
      border: 3px solid var(--border);
      border-top-color: var(--accent-blue);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto 16px;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    .btn-primary {
      background: var(--accent-blue);
      border-color: var(--accent-blue);
    }
    
    .status-active {
      background: rgba(16, 185, 129, 0.1);
      color: var(--accent-green);
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
    }
    
    .status-inactive {
      background: rgba(239, 68, 68, 0.1);
      color: var(--accent-red);
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <header>
    <div class="header-content">
      <div class="logo">
        <div class="logo-icon">🌐</div>
        <span>Domain Control Center</span>
      </div>
      <div class="user-menu">
        <div class="user-avatar" style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-weight: 600; color: white;">SA</div>
      </div>
    </div>
  </header>

  <aside class="sidebar">
    <div class="nav-section">
      <div class="nav-title">Main</div>
      <div class="nav-item active" onclick="showView('overview')">📊 Overview</div>
      <div class="nav-item" onclick="showView('domains')">🌐 Domains</div>
    </div>
    
    <div class="nav-section">
      <div class="nav-title">Content</div>
      <div class="nav-item" onclick="showView('blog')">📝 Blog Posts</div>
    </div>
    
    <div class="nav-section">
      <div class="nav-title">Configuration</div>
      <div class="nav-item" onclick="showView('settings')">⚙️ Settings</div>
    </div>
  </aside>

  <main class="main-content">
    <div class="container">
      <!-- Overview View -->
      <div class="view-section active" id="overview">
        <div class="page-header">
          <h1 class="page-title">Dashboard Overview</h1>
          <p class="page-subtitle">Monitor your domain portfolio performance in real-time</p>
        </div>
        
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Total Domains</span>
              <span>📊</span>
            </div>
            <div class="stat-value">32</div>
            <div class="stat-change positive">+2 this month</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Monthly Visitors</span>
              <span>👥</span>
            </div>
            <div class="stat-value">248.5K</div>
            <div class="stat-change positive">+18.2%</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Blog Posts</span>
              <span>📝</span>
            </div>
            <div class="stat-value">1,847</div>
            <div class="stat-change positive">+124 this week</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">API Calls</span>
              <span>🔌</span>
            </div>
            <div class="stat-value">3.2M</div>
            <div class="stat-change negative">-5.4%</div>
          </div>
        </div>
        
        <h2 style="margin: 24px 0;">Recent Activity</h2>
        <table class="data-table">
          <thead>
            <tr>
              <th>Domain</th>
              <th>Event</th>
              <th>Time</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>gptabsolute.com</td>
              <td>New blog post published</td>
              <td>2 hours ago</td>
              <td><span class="status-active">Success</span></td>
            </tr>
            <tr>
              <td>autowordai.com</td>
              <td>SSL certificate renewed</td>
              <td>5 hours ago</td>
              <td><span class="status-active">Success</span></td>
            </tr>
            <tr>
              <td>empleadosai.com</td>
              <td>DNS records updated</td>
              <td>1 day ago</td>
              <td><span class="status-active">Success</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- Domains View -->
      <div class="view-section" id="domains">
        <div class="page-header">
          <h1 class="page-title">Domain Management</h1>
          <p class="page-subtitle">Manage and configure all your domains from Cloudflare and Netlify</p>
        </div>
        
        <div style="margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center;">
          <div style="display: flex; gap: 12px;">
            <button class="btn btn-primary" onclick="domainManager.fetchAndRender()">🔄 Refresh Domains</button>
            <button class="btn btn-primary">+ Add New Domain</button>
          </div>
          <div style="display: flex; gap: 24px; font-size: 14px;">
            <span>Total: <strong data-stat="total-domains">0</strong></span>
            <span>Active: <strong data-stat="active-domains" style="color: var(--accent-green);">0</strong></span>
            <span>Cloudflare: <strong data-stat="cloudflare-domains" style="color: var(--accent-blue);">0</strong></span>
            <span>Netlify: <strong data-stat="netlify-domains" style="color: var(--accent-yellow);">0</strong></span>
          </div>
        </div>
        
        <table class="data-table">
          <thead>
            <tr>
              <th>Domain</th>
              <th>Status</th>
              <th>Traffic</th>
              <th>Content</th>
              <th>SSL</th>
              <th>Last Modified</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="domains-table-body">
            <!-- Domains will be loaded dynamically -->
            <tr>
              <td colspan="7" style="text-align: center; padding: 40px;">
                <div class="loading-spinner"></div>
                <p>Loading domains...</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- Analytics View -->
      <div class="view-section" id="analytics">
        <div class="page-header">
          <h1 class="page-title">Analytics Dashboard</h1>
          <p class="page-subtitle">Deep insights into your domain performance</p>
        </div>
        
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Page Views</span>
              <span>👁️</span>
            </div>
            <div class="stat-value">1.2M</div>
            <div class="stat-change positive">+22.5%</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Unique Visitors</span>
              <span>👤</span>
            </div>
            <div class="stat-value">248.5K</div>
            <div class="stat-change positive">+18.2%</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Avg. Duration</span>
              <span>⏱️</span>
            </div>
            <div class="stat-value">3:24</div>
            <div class="stat-change positive">+0:15</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Bounce Rate</span>
              <span>📊</span>
            </div>
            <div class="stat-value">42.3%</div>
            <div class="stat-change positive">-3.2%</div>
          </div>
        </div>
        
        <canvas id="analyticsChart" style="background: var(--bg-card); border-radius: 12px; padding: 20px; margin-top: 24px;"></canvas>
      </div>
      
      <!-- Blog View -->
      <div class="view-section" id="blog">
        <div class="page-header">
          <h1 class="page-title">Blog Content Management</h1>
          <p class="page-subtitle">Create and manage blog posts across all domains</p>
        </div>
        
        <div style="margin-bottom: 24px;">
          <button class="btn btn-primary">+ New Post</button>
          <button class="btn">Bulk Import</button>
          <button class="btn">Schedule Posts</button>
        </div>
        
        <table class="data-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Domain</th>
              <th>Author</th>
              <th>Status</th>
              <th>Views</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Understanding AI in 2024</strong></td>
              <td>gptabsolute.com</td>
              <td>AI Writer</td>
              <td><span class="status-active">Published</span></td>
              <td>12.3K</td>
              <td>Dec 10, 2024</td>
            </tr>
            <tr>
              <td><strong>Top 10 SEO Strategies</strong></td>
              <td>autowordai.com</td>
              <td>Content Bot</td>
              <td><span class="status-active">Published</span></td>
              <td>8.7K</td>
              <td>Dec 9, 2024</td>
            </tr>
            <tr>
              <td><strong>Future of Work</strong></td>
              <td>empleadosai.com</td>
              <td>HR Assistant</td>
              <td><span class="status-inactive">Draft</span></td>
              <td>0</td>
              <td>Dec 8, 2024</td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- Media View -->
      <div class="view-section" id="media">
        <div class="page-header">
          <h1 class="page-title">Media Library</h1>
          <p class="page-subtitle">Manage images, videos, and documents</p>
        </div>
        
        <div style="margin-bottom: 24px;">
          <button class="btn btn-primary">+ Upload Media</button>
        </div>
        
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Total Files</span>
              <span>📁</span>
            </div>
            <div class="stat-value">3,842</div>
            <div class="stat-change positive">+124 this week</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Storage Used</span>
              <span>💾</span>
            </div>
            <div class="stat-value">24.7 GB</div>
            <div class="stat-change">of 100 GB</div>
          </div>
          
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">CDN Bandwidth</span>
              <span>🌐</span>
            </div>
            <div class="stat-value">782 GB</div>
            <div class="stat-change">This month</div>
          </div>
        </div>
      </div>
      
      <!-- DNS View -->
      <div class="view-section" id="dns">
        <div class="page-header">
          <h1 class="page-title">DNS Management</h1>
          <p class="page-subtitle">Configure DNS records for your domains</p>
        </div>
        
        <table class="data-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Name</th>
              <th>Value</th>
              <th>TTL</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>A</strong></td>
              <td>@</td>
              <td>104.21.89.234</td>
              <td>Auto</td>
              <td><button class="btn">Edit</button></td>
            </tr>
            <tr>
              <td><strong>CNAME</strong></td>
              <td>www</td>
              <td>gptabsolute.com</td>
              <td>Auto</td>
              <td><button class="btn">Edit</button></td>
            </tr>
            <tr>
              <td><strong>MX</strong></td>
              <td>@</td>
              <td>mail.gptabsolute.com</td>
              <td>3600</td>
              <td><button class="btn">Edit</button></td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- SSL View -->
      <div class="view-section" id="ssl">
        <div class="page-header">
          <h1 class="page-title">SSL Certificate Management</h1>
          <p class="page-subtitle">Manage SSL certificates and security settings</p>
        </div>
        
        <table class="data-table">
          <thead>
            <tr>
              <th>Domain</th>
              <th>Issuer</th>
              <th>Type</th>
              <th>Expires</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>gptabsolute.com</strong></td>
              <td>Let's Encrypt</td>
              <td>Wildcard</td>
              <td>Mar 15, 2025</td>
              <td><span class="status-active">Valid</span></td>
              <td><button class="btn">Renew</button></td>
            </tr>
            <tr>
              <td><strong>autowordai.com</strong></td>
              <td>Let's Encrypt</td>
              <td>Standard</td>
              <td>Feb 28, 2025</td>
              <td><span class="status-active">Valid</span></td>
              <td><button class="btn">Renew</button></td>
            </tr>
            <tr>
              <td><strong>empleadosai.com</strong></td>
              <td>Cloudflare</td>
              <td>Universal</td>
              <td>Jan 10, 2025</td>
              <td><span class="status-inactive">Expiring</span></td>
              <td><button class="btn btn-primary">Renew Now</button></td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- API View -->
      <div class="view-section" id="api">
        <div class="page-header">
          <h1 class="page-title">API Key Management</h1>
          <p class="page-subtitle">Manage API keys and access tokens</p>
        </div>
        
        <div style="margin-bottom: 24px;">
          <button class="btn btn-primary">+ Generate New Key</button>
        </div>
        
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Key</th>
              <th>Permissions</th>
              <th>Last Used</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Production API</strong></td>
              <td>sk_live_**********************3a2f</td>
              <td>Full Access</td>
              <td>2 minutes ago</td>
              <td><span class="status-active">Active</span></td>
              <td><button class="btn">Revoke</button></td>
            </tr>
            <tr>
              <td><strong>Development API</strong></td>
              <td>sk_test_**********************8b4c</td>
              <td>Read Only</td>
              <td>1 hour ago</td>
              <td><span class="status-active">Active</span></td>
              <td><button class="btn">Revoke</button></td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <!-- Settings View -->
      <div class="view-section" id="settings">
        <div class="page-header">
          <h1 class="page-title">Settings</h1>
          <p class="page-subtitle">Configure your account and preferences</p>
        </div>
        
        <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 32px;">
          <h2 style="margin-bottom: 24px;">General Settings</h2>
          
          <div style="margin-bottom: 24px;">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary);">Organization Name</label>
            <input type="text" value="Domain Control Center" style="width: 100%; padding: 12px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 8px; color: white;">
          </div>
          
          <div style="margin-bottom: 24px;">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary);">Primary Email</label>
            <input type="email" value="admin@domaincontrol.com" style="width: 100%; padding: 12px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 8px; color: white;">
          </div>
          
          <div style="margin-bottom: 24px;">
            <label style="display: block; margin-bottom: 8px; color: var(--text-secondary);">Time Zone</label>
            <select style="width: 100%; padding: 12px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 8px; color: white;">
              <option>UTC</option>
              <option selected>America/New_York</option>
              <option>Europe/London</option>
              <option>Asia/Tokyo</option>
            </select>
          </div>
          
          <button class="btn btn-primary">Save Changes</button>
        </div>
      </div>
    </div>
  </main>

  <script>
    function showView(viewName) {
      // Hide all views
      document.querySelectorAll('.view-section').forEach(section => {
        section.classList.remove('active');
      });
      
      // Show selected view
      const targetView = document.getElementById(viewName);
      if (targetView) {
        targetView.classList.add('active');
      }
      
      // Update nav active state
      document.querySelectorAll('.nav-item').forEach(item => {
        item.classList.remove('active');
      });
      event.target.classList.add('active');
      
      console.log('Switched to view:', viewName);
    }
    
    // Initialize chart if on analytics page
    document.addEventListener('DOMContentLoaded', function() {
      const ctx = document.getElementById('analyticsChart');
      if (ctx) {
        new Chart(ctx, {
          type: 'line',
          data: {
            labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
            datasets: [{
              label: 'Visitors',
              data: [32000, 35000, 33000, 38000, 42000, 45000, 41000],
              borderColor: '#3b82f6',
              backgroundColor: 'rgba(59, 130, 246, 0.1)',
              tension: 0.4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: { color: 'rgba(255,255,255,0.05)' },
                ticks: { color: '#a0a0a0' }
              },
              x: {
                grid: { color: 'rgba(255,255,255,0.05)' },
                ticks: { color: '#a0a0a0' }
              }
            }
          }
        });
      }
    });
  </script>
</body>
</html>